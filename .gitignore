# =============================================================================
# OpenTofu / Terraform
# =============================================================================

# State files - contain sensitive data
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Variable files with secrets
*.tfvars
!*.tfvars.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Provider plugins (large binaries)
.terraform/
.terraform.lock.hcl

# =============================================================================
# OS / IDE
# =============================================================================
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# Environment
# =============================================================================
.env
.env.*
